// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// 1. USERS (The Clients using the Mobile App)
// ------------------------------------------------------
model User {
  id               String         @id @default(uuid())
  email            String         @unique
  password         String
  name             String
  createdAt        DateTime       @default(now())
  profilePictureUrl String?
  
  // --- STRIPE UPDATE ---
  stripeCustomerId String?        @unique

  subscriptions    Subscription[]
  usedCodes        AccessCode[]
  
  // --- FORUM UPDATE ---
  posts            Post[]
  comments         Comment[]

  // --- MESSAGING UPDATE ---
  sentMessages     Message[]      @relation("SenderUser")
  receivedMessages Message[]      @relation("ReceiverUser")
}

// ------------------------------------------------------
// 2. COACHES (The Admins using the Web Dashboard)
// ------------------------------------------------------
model Coach {
  id                String           @id @default(uuid())
  name              String
  email             String           @unique
  password          String
  specialty         String
  bio               String?
  profilePictureUrl String?  

  // --- COACH PROFILE UPDATE (Feature 5) ---
  coverImageUrl     String?
  tagline           String?
  offerings         String?

  // --- STRIPE UPDATE ---
  subscriptionPrice Float            @default(19.99)

  // Relationships
  videos            Video[]
  subscriptions     Subscription[]
  accessCodes       AccessCode[]
  recommendations   Recommendation[]
  
  // --- FORUM UPDATE ---
  posts             Post[]
  comments          Comment[]

  // --- MESSAGING UPDATE ---
  sentMessages      Message[]        @relation("SenderCoach")
  receivedMessages  Message[]        @relation("ReceiverCoach")
}

// ------------------------------------------------------
// 3. VIDEOS (Uploaded by Coaches)
// ------------------------------------------------------
model Video {
  id        String   @id @default(uuid())
  title     String
  url       String
  category  String
  createdAt DateTime @default(now())

  coachId   String
  coach     Coach    @relation(fields: [coachId], references: [id])
}

// ------------------------------------------------------
// 4. SUBSCRIPTIONS (Links a User to a Coach)
// ------------------------------------------------------
model Subscription {
  id                   String   @id @default(uuid())
  status               String
  
  stripeSubscriptionId String?  @unique

  startDate            DateTime @default(now())
  endDate              DateTime
  
  userId               String
  user                 User     @relation(fields: [userId], references: [id])
  coachId              String
  coach                Coach    @relation(fields: [coachId], references: [id])
}

// ------------------------------------------------------
// 5. ACCESS CODES (Given by Coaches to real-life clients)
// ------------------------------------------------------
model AccessCode {
  id        String    @id @default(uuid())
  code      String    @unique
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  coachId   String
  coach     Coach     @relation(fields: [coachId], references: [id])
  usedBy    String?
  user      User?     @relation(fields: [usedBy], references: [id])
}

// ------------------------------------------------------
// 6. RECOMMENDATIONS
// ------------------------------------------------------
model Recommendation {
  id        String   @id @default(uuid())
  type      String
  content   String
  createdAt DateTime @default(now())

  coachId   String
  coach     Coach    @relation(fields: [coachId], references: [id])
}

// ------------------------------------------------------
// 7. POSTS (Forum)
// ------------------------------------------------------
model Post {
  id        String   @id @default(uuid())
  title     String
  content   String
  createdAt DateTime @default(now())

  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  coachId   String?
  coach     Coach?   @relation(fields: [coachId], references: [id])

  comments  Comment[]
}

// ------------------------------------------------------
// 8. COMMENTS
// ------------------------------------------------------
model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())

  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  coachId   String?
  coach     Coach?   @relation(fields: [coachId], references: [id])
}

// ------------------------------------------------------
// 9. MESSAGES (Client <-> Coach DMs)
// ------------------------------------------------------
model Message {
  id         String   @id @default(uuid())
  content    String
  createdAt  DateTime @default(now())
  read       Boolean  @default(false)

  senderType String   // 'user' or 'coach'

  userId     String
  user       User     @relation("SenderUser", fields: [userId], references: [id])
  coachId    String
  coach      Coach    @relation("SenderCoach", fields: [coachId], references: [id])

  sentByUserId  String?
  sentByUser    User?   @relation("ReceiverUser", fields: [sentByUserId], references: [id])
  sentByCoachId String?
  sentByCoach   Coach?  @relation("ReceiverCoach", fields: [sentByCoachId], references: [id])
}