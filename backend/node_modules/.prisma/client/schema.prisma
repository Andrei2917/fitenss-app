// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// 1. USERS (The Clients using the Mobile App)
// ------------------------------------------------------
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())

  // --- STRIPE UPDATE ---
  stripeCustomerId String? @unique // Saves their credit card profile!

  subscriptions Subscription[]
  usedCodes     AccessCode[]

  // --- FORUM UPDATE ---
  posts    Post[]
  comments Comment[]
}

// ------------------------------------------------------
// 2. COACHES (The Admins using the Web Dashboard)
// ------------------------------------------------------
model Coach {
  id        String  @id @default(uuid())
  name      String
  email     String  @unique
  password  String
  specialty String
  bio       String?

  // --- STRIPE UPDATE ---
  subscriptionPrice Float @default(19.99) // Allows coaches to set their own price!

  // Relationships
  videos          Video[]
  subscriptions   Subscription[]
  accessCodes     AccessCode[]
  recommendations Recommendation[]

  // --- FORUM UPDATE ---
  posts    Post[]
  comments Comment[]
}

// ------------------------------------------------------
// 3. VIDEOS (Uploaded by Coaches)
// ------------------------------------------------------
model Video {
  id        String   @id @default(uuid())
  title     String
  url       String // This will hold the Vimeo link
  category  String
  createdAt DateTime @default(now())

  // Relationship: Belongs to a specific Coach
  coachId String
  coach   Coach  @relation(fields: [coachId], references: [id])
}

// ------------------------------------------------------
// 4. SUBSCRIPTIONS (Links a User to a Coach)
// ------------------------------------------------------
model Subscription {
  id     String @id @default(uuid())
  status String // e.g., 'pending', 'active', 'expired', 'cancelled'

  // --- STRIPE UPDATE ---
  stripeSubscriptionId String? @unique // Links this database row to the actual Stripe receipt

  startDate DateTime @default(now())
  endDate   DateTime

  // Relationships: Belongs to one User and one Coach
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  coachId String
  coach   Coach  @relation(fields: [coachId], references: [id])
}

// ------------------------------------------------------
// 5. ACCESS CODES (Given by Coaches to real-life clients)
// ------------------------------------------------------
model AccessCode {
  id        String    @id @default(uuid())
  code      String    @unique
  usedAt    DateTime? // If null, the code hasn't been used yet
  createdAt DateTime  @default(now())

  // Relationships
  coachId String
  coach   Coach   @relation(fields: [coachId], references: [id])
  usedBy  String? // ID of the User who redeemed it
  user    User?   @relation(fields: [usedBy], references: [id])
}

// ------------------------------------------------------
// 6. RECOMMENDATIONS (Coach's text/links for the 4th Tab)
// ------------------------------------------------------
model Recommendation {
  id        String   @id @default(uuid())
  type      String // e.g., 'text', 'equipment_link'
  content   String // The actual text advice or the URL for the equipment
  createdAt DateTime @default(now())

  // Relationship: Belongs to a specific Coach
  coachId String
  coach   Coach  @relation(fields: [coachId], references: [id])
}

// ------------------------------------------------------
// 7. POSTS (Forum Questions / Discussions)
// ------------------------------------------------------
model Post {
  id        String   @id @default(uuid())
  title     String
  content   String
  createdAt DateTime @default(now())

  // The Author (Can be EITHER a User OR a Coach)
  userId  String?
  user    User?   @relation(fields: [userId], references: [id])
  coachId String?
  coach   Coach?  @relation(fields: [coachId], references: [id])

  // A post can have many comments
  comments Comment[]
}

// ------------------------------------------------------
// 8. COMMENTS (Replies to Forum Posts)
// ------------------------------------------------------
model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())

  // Which Post this comment belongs to
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  // The Author (Can be EITHER a User OR a Coach)
  userId  String?
  user    User?   @relation(fields: [userId], references: [id])
  coachId String?
  coach   Coach?  @relation(fields: [coachId], references: [id])
}
